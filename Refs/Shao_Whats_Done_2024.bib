
@misc{ShaoWhatsDoneCannot2024,
  title = {What's Done Cannot Be Undone: {TASI} Lectures on Non-Invertible
           Symmetries},
  url = {http://arxiv.org/abs/2308.00747},
  doi = {10.48550/arXiv.2308.00747},
  shorttitle = {What's Done Cannot Be Undone},
  abstract = {We survey recent developments in a novel kind of generalized
              global symmetry, the non-invertible symmetry, in diverse spacetime
              dimensions. We start with several different but related
              constructions of the non-invertible Kramers-Wannier duality
              symmetry in the Ising model, and conclude with a new interpretation
              for the neutral pion decay and other applications. These notes are
              based on lectures given at the {TASI} 2023 summer school "Aspects
              of Symmetry."},
  number = {{arXiv}:2308.00747},
  publisher = {{arXiv}},
  author = {Shao, Shu-Heng},
  urldate = {2026-02-17},
  date = {2024-03-30},
  eprinttype = {arxiv},
  eprint = {2308.00747 [hep-th]},
  keywords = {Condensed Matter - Strongly Correlated Electrons, High Energy
              Physics - Phenomenology, Mathematics - Category Theory, High Energy
              Physics - Theory, Mathematics - Quantum Algebra},
}
